{
    "$schema": "./@types/schema/package/index.json",
    "package_version": 2,
    "name": "cocos-mcp-server",
    "version": "0.1.0",
    "author": "andsky",
    "editor": ">=3.8.6",
    "scripts": {
        "preinstall": "node ./scripts/preinstall.js",
        "build": "tsc",
        "watch": "tsc -w"
    },
    "description": "MCP server for Cocos Creator editor — control nodes, components, assets, scenes via AI assistants",
    "main": "./dist/main.js",
    "dependencies": {
        "fs-extra": "^11.3.0",
        "uuid": "^9.0.1",
        "vue": "^3.1.4"
    },
    "devDependencies": {
        "@cocos/creator-types": "^3.8.6",
        "@types/fs-extra": "^9.0.5",
        "@types/node": "^18.17.1",
        "@types/uuid": "^9.0.8",
        "typescript": "^5.8.2"
    },
    "panels": {
        "default": {
            "title": "Cocos MCP Server",
            "type": "dockable",
            "main": "dist/panels/default",
            "size": {
                "min-width": 400,
                "min-height": 300,
                "width": 600,
                "height": 500
            }
        }
    },
    "contributions": {
        "menu": [
            {
                "path": "i18n:menu.extension/Cocos MCP Server",
                "label": "Open Panel",
                "message": "open-panel"
            }
        ],
        "messages": {
            "open-panel": {
                "methods": ["openPanel"]
            },
            "start-server": {
                "methods": ["startServer"]
            },
            "stop-server": {
                "methods": ["stopServer"]
            },
            "get-server-status": {
                "methods": ["getServerStatus"]
            },
            "update-settings": {
                "methods": ["updateSettings"]
            },
            "get-server-settings": {
                "methods": ["getServerSettings"]
            },
            "getToolsList": {
                "methods": ["getToolsList"]
            }
        },
        "scene": {
            "script": "./dist/scene.js",
            "methods": [
                "playAnimation",
                "pauseAnimation",
                "stopAnimation",
                "getAnimationTracks",
                "startAnimationRecord",
                "stopAnimationRecord",
                "cancelAnimationRecord",
                "executeScript",
                "queryScriptMethods",
                "queryScriptProperties"
            ]
        }
    }
}
