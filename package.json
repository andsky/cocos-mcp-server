{
    "$schema": "./@types/schema/package/index.json",
    "package_version": 2,
    "name": "cocos-mcp-server",
    "version": "0.1.0",
    "author": "andsky",
    "editor": ">=3.8.6",
    "scripts": {
        "preinstall": "node ./scripts/preinstall.js",
        "build": "tsc",
        "watch": "tsc -w"
    },
    "description": "MCP server for Cocos Creator editor — control nodes, components, assets, scenes via AI assistants",
    "main": "./dist/main.js",
    "dependencies": {
        "fs-extra": "^11.3.0",
        "uuid": "^9.0.1",
        "vue": "^3.1.4"
    },
    "devDependencies": {
        "@cocos/creator-types": "^3.8.6",
        "@types/fs-extra": "^9.0.5",
        "@types/node": "^18.17.1",
        "@types/uuid": "^9.0.8",
        "typescript": "^5.8.2"
    },
    "panels": {
        "default": {
            "title": "Cocos MCP Server",
            "type": "dockable",
            "main": "./dist/panels/default",
            "icon": "./static/icon.png",
            "size": {
                "min-width": 400,
                "min-height": 300,
                "width": 600,
                "height": 500
            }
        }
    },
    "contributions": {
        "profile": {
            "editor": {
                "port": {
                    "default": 3000,
                    "message": "cocos-mcp-server:settings-changed",
                    "label": "Server Port"
                },
                "autoStart": {
                    "default": false,
                    "message": "cocos-mcp-server:settings-changed",
                    "label": "Auto Start"
                },
                "enableDebugLog": {
                    "default": false,
                    "message": "cocos-mcp-server:settings-changed",
                    "label": "Enable Debug Log"
                },
                "allowedOrigins": {
                    "default": ["*"],
                    "message": "cocos-mcp-server:settings-changed",
                    "label": "Allowed CORS Origins"
                },
                "maxConnections": {
                    "default": 10,
                    "message": "cocos-mcp-server:settings-changed",
                    "label": "Max Connections"
                }
            }
        },
        "menu": [
            {
                "path": "i18n:menu.extension/Cocos MCP Server",
                "label": "Open Panel",
                "message": "open-panel"
            },
            {
                "path": "i18n:menu.extension/Cocos MCP Server",
                "label": "Start Server",
                "message": "start-server"
            },
            {
                "path": "i18n:menu.extension/Cocos MCP Server",
                "label": "Stop Server",
                "message": "stop-server"
            }
        ],
        "shortcuts": [
            {
                "message": "open-panel",
                "label": "Open MCP Panel",
                "accelerator": "CmdOrCtrl+Shift+M"
            },
            {
                "message": "start-server",
                "label": "Start MCP Server",
                "accelerator": "CmdOrCtrl+Shift+Alt+S"
            },
            {
                "message": "stop-server",
                "label": "Stop MCP Server",
                "accelerator": "CmdOrCtrl+Shift+Alt+X"
            }
        ],
        "messages": {
            "open-panel": {
                "methods": ["openPanel"]
            },
            "start-server": {
                "methods": ["startServer"]
            },
            "stop-server": {
                "methods": ["stopServer"]
            },
            "get-server-status": {
                "methods": ["getServerStatus"]
            },
            "update-settings": {
                "methods": ["updateSettings"]
            },
            "get-server-settings": {
                "methods": ["getServerSettings"]
            },
            "getToolsList": {
                "methods": ["getToolsList"]
            },
            "settings-changed": {
                "public": true,
                "description": "Server settings changed notification"
            }
        },
        "scene": {
            "script": "./dist/scene.js",
            "methods": [
                "playAnimation",
                "pauseAnimation",
                "stopAnimation",
                "getAnimationTracks",
                "startAnimationRecord",
                "stopAnimationRecord",
                "cancelAnimationRecord",
                "executeScript",
                "queryScriptMethods",
                "queryScriptProperties",
                "createTween",
                "stopTween",
                "stopAllTweens",
                "setSpineAnimation",
                "getSpineInfo",
                "setSpineMix",
                "pauseSpine",
                "setDragonBonesAnimation",
                "getDragonBonesInfo",
                "executeGraphics",
                "playAudio",
                "pauseAudio",
                "stopAudio",
                "scrollScrollView",
                "setPageViewIndex",
                "getSceneStatistics",
                "createPrefabTemplate",
                "unlinkPrefab",
                "createPrefabFromNode",
                "getTiledMapLayers",
                "getTiledMapProperties",
                "setGizmoTool",
                "setGizmoCoordinate",
                "setGizmoPivot",
                "setGridVisible",
                "queryGridVisible",
                "setViewMode",
                "cameraOperation",
                "querySceneViewStatus"
            ]
        }
    }
}
